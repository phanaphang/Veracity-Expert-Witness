# Supabase (server-side / Vercel Functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paubox email API
PAUBOX_API_USER=your-paubox-api-user
PAUBOX_API_KEY=your-paubox-api-key

# Email recipients (defaults shown)
CONTACT_EMAIL=info@veracityexpertwitness.com
ADMIN_EMAIL=admin@veracityexpertwitness.com

# Frontend vars (also needed by Vercel build)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
